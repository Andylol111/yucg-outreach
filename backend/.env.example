# Apify API token for LinkedIn employee scraping (get one at https://console.apify.com)
APIFY_API_TOKEN=your_apify_token_here

# Tavily API key for "Find contact" web search (get one at https://tavily.com). Optional.
# TAVILY_API_KEY=your_tavily_api_key_here

# Google OAuth for Sign in with Google (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Must match exactly what you add under "Authorized redirect URIs" in Google Cloud (usually the API origin, not Vite).
BACKEND_URL=http://localhost:8000
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# Where users open the app — must match the browser URL (http://127.0.0.1:5173 vs http://localhost:5173 matters for cookies).
FRONTEND_URL=http://localhost:5173
# Comma-separated origins for CORS when public (e.g. https://outreach.yucg.org). If unset, localhost is used.
# CORS_ORIGINS=https://your-frontend-domain.com

# JWT secret for session tokens and OAuth state signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=your_jwt_secret_here
# Optional: separate HMAC key for OAuth `state` only (defaults to JWT_SECRET)
# OAUTH_STATE_SECRET=

# Ollama (local LLM for email generation and Operations Intelligence). Optional.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Slack (optional). Two options:
# (1) OAuth: Profile -> Connect Slack + per-user digest DMs. Client ID + Client Secret from
#     api.slack.com/apps -> your app -> Basic Information -> App Credentials.
# (2) Bot token only: use Access Token (xoxb-...) to post daily digest to a channel.
# You do NOT need: Signing Secret (only for Events/Slash/Interactivity); App ID is not used.
# SLACK_CLIENT_ID=your_slack_client_id
# SLACK_CLIENT_SECRET=your_slack_client_secret
# SLACK_BOT_TOKEN=xoxb-your-bot-access-token
# SLACK_DIGEST_CHANNEL_ID=C01234ABCD
# BACKEND_URL=http://localhost:8000

# SSL cert paths for HTTPS (start-https.sh). Default: certs/key.pem, certs/cert.pem
# Use absolute paths or paths relative to backend/ to keep keys outside the repo
# SSL_KEY_PATH=certs/key.pem
# SSL_CERT_PATH=certs/cert.pem
